#!/usr/bin/env bash

project_dir=$(
find ~/mzd/code \
    -mindepth 2 -maxdepth 2 -type d \
    ! -path '*.git' \
    ! -path '*node_modules*' | fzf
)

if [[ -z $project_dir ]]; then
    exit 1
fi

session_name=$(basename "$project_dir" | tr . _)

# if a session with the same name exists, just switch to it
if tmux has-session -t="$session_name" 2> /dev/null; then
    if [[ -n $TMUX ]]; then
        tmux switch-client -t "$session_name"
    else
        tmux attach-session -t "$session_name"
    fi
    exit 0
fi

# by now, we know that we need to create a new session
if [[ -n $TMUX ]]; then
    tmux new-session -ds "$session_name" -c "$project_dir";
    tmux switch-client -t "$session_name" \; \
        send-keys -t 1 "nvim" Enter \; \
        neww -n shell -c "$project_dir" \; \
        selectw -t 1
else
    tmux new-session -s "$session_name" -c "$project_dir"\; \
        send-keys -t 1 "nvim" Enter \; \
        neww -n shell \; \
        selectw -t 1
fi
