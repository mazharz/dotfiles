#!/bin/bash

# usage:
# $ gpg-loop encode *.ogg
# $ gpg-loop decode *.ogg.gpg

args=("$@")

read -r -s -p "Pass: " pass
echo # go on next line after getting pass

if [ "${args[0]}" == "encode" ]; then
  for ((i=1; i < ${#args[@]}; i++)); do
    gpg -c --cipher-algo aes256 --batch --passphrase "$pass" "${args[$i]}"
  done
elif [ "${args[0]}" == "decode" ];then
  for ((i=1; i < ${#args[@]}; i++)); do
    gpg --batch --passphrase "$pass" "${args[$i]}"
  done
fi
