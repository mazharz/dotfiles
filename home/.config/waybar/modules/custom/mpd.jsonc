{
  "custom/mpd": {
    "exec": "~/.config/waybar/modules/custom/mpd.sh",
    "interval": 10,
    "tooltip": false,
    "signal": 7,
    "on-click": "mpc toggle",
    "on-click-right": "mpc next",
    "on-click-middle": "mpc prev",
    "on-scroll-up": "mpc seek +10",
    "on-scroll-down": "mpc seek -10",
  },
}
